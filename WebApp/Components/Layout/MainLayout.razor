@inherits LayoutComponentBase

@* Required *@
<MudThemeProvider />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="MudBlazor.Color.Inherit" Edge="Edge.Start"
                        OnClick="@((e) => DrawerToggle())" />
        <MudSpacer />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h5" Class="mt-1">C# vs Python</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="carPricePrediction" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.AccountBalance">
                Car Prediction
            </MudNavLink>
        </MudNavMenu>
        <MudNavMenu>
            <MudNavLink Href="sentimentAnalysis" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.SentimentNeutral">
                Sentiment Analysis
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>

</MudLayout>


@code{
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

}