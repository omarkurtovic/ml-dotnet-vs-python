@page "/lungCancer/trainer"
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using SharedCL.LungCancerPrediction.Models
@using SharedCL.Shared.Enums
@using SharedCL.Shared.Models
@using WebApp.LungCancerPrediction.ApiClients
@using WebApp.SharedKernel
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@inject CSharpLungCancerApiClient CSharpLungCancerApi
@inject PythonLungCancerApiClient PythonLungCancerApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IConfiguration Configuration
@rendermode InteractiveServer

<PageTitle>Treniranje Modela za Rak Pluća</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mb-16">
    <MudPaper Class="pa-6 mt-6" Elevation="15">
        <MudGrid>
            <MudItem xs="12" Style="position: relative; display: flex; align-items: center;">
                <MudIconButton Style="margin-left: 24px; position: absolute; left: 0;" Icon="@Icons.Material.Filled.ArrowBack"
                               Variant="Variant.Filled" Color="Color.Primary" Href="/lungCancer" />
                <MudText Style="width: 100%; text-align: center;" Typo="Typo.h5">Treniranje Modela</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudForm @ref="_form">
                    <MudPaper Outlined="true" Class="pa-4 mb-4">
                        <MudTextField @bind-Value="trainingParams.ModelName" Required="true"
                                      RequiredError="Naziv modela je obavezan!" Variant="Variant.Outlined" Label="Naziv modela" Class="mb-4" />

                        <MudSelect T="ModelLanguage" @bind-Value="trainingParams.ModelLanguage" Label="Jezik modela"
                                   Variant="Variant.Outlined" Required="true" RequiredError="Model Mašinskog Učenja je obavezan!" Class="mb-4">
                            @foreach (var item in Enum.GetValues<ModelLanguage>())
                            {
                                <MudSelectItem Value="@item">@item.ToString()</MudSelectItem>
                            }
                        </MudSelect>
                    </MudPaper>
                </MudForm>
            </MudItem>
            <MudItem xs="12" Style="display: flex; justify-content: center; gap:1rem;">
                @if (!isTrainingDisabled)
                {
                <MudButton OnClick="TrainModel" Color="Color.Primary" Variant="Variant.Filled"
                           Size="Size.Large" Disabled="_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Treniranje...</span>
                    }
                    else
                    {
                        <span>Treniraj</span>
                    }
                </MudButton>
                }
                @if (model != null)
                {
                    <MudButton OnClick="ShowModelDetails" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                        Prikaži Rezultate
                    </MudButton>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>


@code {

    private MudForm _form = null!;
    private LungCancerTrainingParams trainingParams = new LungCancerTrainingParams();

    private LungCancerModel? model;
    private bool _isLoading = false;
    private bool isTrainingDisabled;

    protected override void OnInitialized()
    {
        isTrainingDisabled = Configuration.GetValue<bool>("TRAINING_DISABLED");
    }

    private async Task TrainModel()
    {
        await _form.Validate();
        if (!_form.IsValid)
            return;

        _isLoading = true;
        StateHasChanged();

        Result<LungCancerModel> result;
        if (trainingParams.ModelLanguage == ModelLanguage.CSharp)
        {
            result = await CSharpLungCancerApi.TrainModelAsync(trainingParams);
        }
        else
        {
            result = await PythonLungCancerApi.TrainModelAsync(trainingParams);
        }

        _isLoading = false;

        if (result.IsSuccess)
        {
            model = result.Data!;
            await ShowModelDetails();
            Snackbar.Add("Model je uspešno treniran!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Greška prilikom treniranja modela.", Severity.Error);
        }
    }

    private async Task ShowModelDetails()
    {
        var parameters = new DialogParameters<LungCancerInfoDialog>
        {
            { x => x.Model, model },
            { x => x.ShowSaveOption, true }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        await DialogService.ShowAsync<LungCancerInfoDialog>("Detalji Modela", parameters, options);
    }
}
