@page "/lungCancer"
@inject IConfiguration Configuration
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="mb-16">
    <MudPaper Class="pa-6 mt-6" Elevation="15">
        <MudGrid>
            <MudItem xs="12" Style="display: flex; justify-content: center; margin-bottom: 20px;">
                <MudText Typo="Typo.h3">Rak pluća</MudText>
            </MudItem>
            <MudItem xs="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/lungCancer/inference" FullWidth
                           StartIcon="@Icons.Material.Filled.PlayArrow">
                    Pokreni analizu
                </MudButton>
            </MudItem>
            @if (isTrainingDisabled)
            {
                <MudItem xs="4">
                    <MudTooltip Text="Treniranje modela je onemogućeno" Placement="Placement.Top">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth StartIcon="@Icons.Material.Filled.ModelTraining" Disabled>
                            Traniraj Model
                        </MudButton>
                    </MudTooltip>
                </MudItem>
            }
            else
            {
                <MudItem xs="4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/lungCancer/trainer" FullWidth
                               StartIcon="@Icons.Material.Filled.ModelTraining">
                        Traniraj Model
                    </MudButton>
                </MudItem>
            }
            <MudItem xs="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/lungCancer/models" FullWidth
                           StartIcon="@Icons.Material.Filled.List">
                    Pregled Modela
                </MudButton>
            </MudItem>

            <MudExpansionPanel Text="Opis">
                <MudText>
                </MudText>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Podaci">
                <MudText>
                    <MudLink Href="https://www.kaggle.com/datasets/adityamahimkar/iqothnccd-lung-cancer-dataset">Podaci</MudLink>
                </MudText>
            </MudExpansionPanel>

            <MudExpansionPanel Text="Treniranje">
                <MudText>
                </MudText>
            </MudExpansionPanel>
        </MudGrid>
    </MudPaper>
</MudContainer>



@code {
    private bool isTrainingDisabled = false;

    protected override Task OnInitializedAsync()
    {
        isTrainingDisabled = Configuration.GetValue<bool>("TRAINING_DISABLED");
        return base.OnInitializedAsync();
    }
}