@using MudBlazor
@using SharedCL.SentimentAnalysis.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />Performanse Modela</MudText>
    </TitleContent>
    <DialogContent>
        @if (Model != null)
        {
            <MudGrid>
                <MudData
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showResults = false)" Color="Color.Primary" Variant="Variant.Filled">Zatvori</MudButton>
    </DialogActions>
</MudDialog>


@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public SentimentAnalysisModel Model { get; set; } = null!;

    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
