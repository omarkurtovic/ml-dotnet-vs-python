@page "/carPricePrediction"
@using CsvHelper
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.ML
@using MudBlazor
@using System.Globalization
@using SharedCL.CarValuePrediction.Mappings
@using SharedCL.CarValuePrediction.Models
@using WebApp.CarValuePrediction.Models
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer

<PageTitle>Car Price Prediction</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Class="pa-6 mt-6" Elevation="15">
        <MudForm @ref="_form">
            <MudText Typo="Typo.h5" Class="mb-4">Car Price Prediction</MudText>

            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Vehicle Identity</b></MudText>
                <MudGrid>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="CarInfoDto.Manufacturer" Label="Manufacturer" Required="true"
                                   RequiredError="Manufacturer is required" Variant="Variant.Outlined">
                            @foreach (string item in Manufactureres)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="CarInfoDto.Model" Label="Model" Required="true"
                                   RequiredError="Model is required" Variant="Variant.Outlined">
                            @foreach (var item in Models.Where(m => m.Manufacturer == CarInfoDto.Manufacturer).ToList())
                            {
                                <MudSelectItem Value="@item.Model">@item.Model</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="int" @bind-Value="CarInfoDto.ProdYear" Label="Production Year" Required="true"
                                         RequiredError="Production year is required" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="CarInfoDto.Category" Label="Category" Variant="Variant.Outlined">
                            @foreach (var item in Categories)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Fuel &amp; Engine</b></MudText>
                <MudGrid>
                    <MudItem xs="4">
                        <MudSelect T="string" @bind-Value="CarInfoDto.FuelType" Label="Fuel Type" Variant="Variant.Outlined">
                            @foreach (var item in FuelTypes)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSelect T="string" @bind-Value="CarInfoDto.EngineVolume" Label="Engine Volume" Variant="Variant.Outlined">
                            @foreach (var item in EngineVolumes)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="4">
                        <MudNumericField T="int" @bind-Value="CarInfoDto.Cylinders" Label="Cylinders" Min="0" Max="10"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Usage</b></MudText>
                <MudGrid>
                    <MudItem xs="6">
                        <MudNumericField T="int" @bind-Value="CarInfoDto.Mileage" Label="Mileage" Required="true"
                                         RequiredError="Mileage is required" Min="0" Max="1000000"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="CarInfoDto.Color" Label="Color" Variant="Variant.Outlined">
                            @foreach (var item in Colors)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Safety &amp; Extras</b></MudText>
                <MudGrid>
                    <MudItem xs="4">
                        <MudNumericField T="int" @bind-Value="CarInfoDto.Airbags" Label="Airbags" Min="0" Max="10"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudCheckBox @bind-Value="CarInfoDto.LeatherInterior" Label="Leather Interior" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudCheckBox @bind-Value="CarInfoDto.RightWheel" Label="Right-Hand Drive" />
                    </MudItem><MudItem xs="4">
                        <MudSelect T="string" @bind-Value="CarInfoDto.GearBoxType" Label="Gear Box Type" Variant="Variant.Outlined">
                            @foreach (var item in GearBoxes)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSelect T="string" @bind-Value="CarInfoDto.DriveWheels" Label="Drive Wheels" Variant="Variant.Outlined">
                            @foreach (var item in DriveWheels)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="4">
                        <MudNumericField T="int" @bind-Value="CarInfoDto.Doors" Label="Doors" Min="0" Max="10"
                                         Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Machine Learning Model</b></MudText>
                <MudGrid>
                    <MudItem xs="12">
                        <MudSelect T="string" @bind-Value="MLModel" Label="Model" Variant="Variant.Outlined"
                                   Required="true" RequiredError="Machine Learning Model is required!">
                            @foreach (var item in MLModels)
                            {
                                <MudSelectItem Value="@item">@item</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudForm>
        <MudItem xs="12" Class="d-flex justify-center gap-2 mt-6">
            <MudButton OnClick="Predict" Color="Color.Primary" Variant="Variant.Filled">Predict</MudButton>
            @if(!string.IsNullOrWhiteSpace(Prediction))
            {
                <MudText Typo="Typo.subtitle1" Class="mb-3">Price Prediction: <b>@Prediction</b></MudText>
            }
        </MudItem>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;

    private List<string> Manufactureres { get; set; } = new();
    private List<(string Manufacturer, string Model)> Models { get; set; } = new();
    private List<string> Categories { get; set; } = new();
    private List<string> FuelTypes { get; set; } = new();
    private List<string> EngineVolumes { get; set; } = new();
    private List<string> GearBoxes { get; set; } = new();
    private List<string> DriveWheels { get; set; } = new();
    private List<string> Colors { get; set; } = new();

    private CarInfoDto CarInfoDto = new();

    private List<string> MLModels { get; set; } = new List<string>();
    private string MLModel = "";

    private string Prediction = "";

    protected override Task OnInitializedAsync()
    {
        CarInfoDto = new();
        CarInfoDto.ProdYear = DateTime.Now.Year;

        var repoRoot = Path.GetFullPath(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..", "..", "..", ".."));
        var dataPath = Path.Combine(repoRoot, "data", "car-prediction", "train.csv");

        var records = new List<CarInfoForCsv>();
        using (var reader = new StreamReader(dataPath))
        using (var csv = new CsvReader(reader, CultureInfo.InvariantCulture))
        {
            records = csv.GetRecords<CarInfoForCsv>().ToList();
        }

        Manufactureres = records.Select(ci => ci.Manufacturer).Distinct().ToList();
        Models = records.Select(ci => (ci.Manufacturer, ci.Model)).Distinct().ToList();
        Categories = records.Select(ci => ci.Category).Distinct().ToList();
        FuelTypes = records.Select(ci => ci.FuelType).Distinct().ToList();
        EngineVolumes = records.Select(ci => ci.EngineVolume).Distinct().ToList();
        GearBoxes = records.Select(ci => ci.GearBoxType).Distinct().ToList();
        DriveWheels = records.Select(ci => ci.DriveWheels).Distinct().ToList();
        Colors = records.Select(ci => ci.Color).Distinct().ToList();

        MLModels = new List<string>()
        {
            "C# FastForest",
            "Python RandomForestRegressor"
        };
        return base.OnInitializedAsync();
    }

    private async Task Predict()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            StateHasChanged();
            return;
        }

        var repoRoot = Path.GetFullPath(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..", "..", "..", ".."));

        var modelPath = Path.Combine(repoRoot, "models", "car-prediction", "csharp", "csharp_rf_carprice.zip");

        MLContext mlContext = new MLContext();
        mlContext.ComponentCatalog.RegisterAssembly(typeof(MileageCleanerMapping).Assembly);
        ITransformer trainedModel = mlContext.Model.Load(modelPath, out var modelInputSchema);


        var carInfo = new CarInfoInput
        {
            Manufacturer = CarInfoDto.Manufacturer,
            Model = CarInfoDto.Model,
            ProdYear = CarInfoDto.ProdYear,
            Category = CarInfoDto.Category,
            LeatherInterior = CarInfoDto.LeatherInterior ? "Yes" : "No",
            FuelType = CarInfoDto.FuelType,
            EngineVolume = CarInfoDto.EngineVolume,
            MileageKm = CarInfoDto.Mileage.ToString(),
            Cylinders = CarInfoDto.Cylinders,
            GearBoxType = CarInfoDto.GearBoxType,
            DriveWheels = CarInfoDto.DriveWheels,
            Doors = CarInfoDto.Doors.ToString(),
            Wheel = CarInfoDto.RightWheel ? "Right-hand drive" : "Left wheel",
            Color = CarInfoDto.Color,
            Airbags = CarInfoDto.Airbags
        };
        var predictionEngine = mlContext.Model.CreatePredictionEngine<CarInfoInput, PricePrediction>(trainedModel);

        PricePrediction prediction = predictionEngine.Predict(carInfo);



        Prediction = prediction.Price.ToString();

    }
}
